FROM python:3.12-slim

ENV PYTHONDONTWRITEBYTECODE=1 \
    PYTHONUNBUFFERED=1 \
    PIP_NO_CACHE_DIR=1 \
    SSL_CERTFILE=/app/certs/skillserver.fullchain.crt \
    SSL_KEYFILE=/app/certs/skillserver.key

WORKDIR /app

RUN apt-get update \
    && apt-get install -y --no-install-recommends ca-certificates \
    && rm -rf /var/lib/apt/lists/*

COPY requirements.txt ./
RUN pip install --root-user-action=ignore -r requirements.txt \
    && playwright install --with-deps chromium \
    && rm -rf /root/.cache/ms-playwright/chromium-*/  \
    && rm -rf /root/.cache/ms-playwright/ffmpeg-*/    \
    && apt-get autoremove -y \
    && apt-get clean \
    && rm -rf /var/lib/apt/lists/* /tmp/* /root/.cache/pip \
    && find /usr -name '*.pyc' -delete 2>/dev/null || true

COPY certs/skillserver-ca.crt /usr/local/share/ca-certificates/skillserver-local-ca.crt
COPY certs/skillserver.crt /app/certs/skillserver.crt
COPY certs/skillserver.key /app/certs/skillserver.key
COPY certs/skillserver.fullchain.crt /app/certs/skillserver.fullchain.crt

RUN update-ca-certificates \
    && chmod 600 /app/certs/skillserver.key

EXPOSE 3000

CMD ["python", "server.py"]

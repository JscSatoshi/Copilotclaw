{
  "gateway": {
    "port": 18789,
    "bind": "loopback",
    "mode": "local",
    "auth": {
      "mode": "token"
    },
    "controlUi": {
      "allowInsecureAuth": true,
      "enabled": true,
      "allowedOrigins": [
        "*"
      ]
    }
  },
  "agents": {
    "defaults": {
      "workspace": "/data/workspace",
      "model": {
        "primary": "github-copilot/claude-sonnet-4.6"
      }
    }
  },
  "acp": {
    "defaultAgent": "main"
  },
  "browser": {
    "enabled": false
  },
  "tools": {
    "web": {
      "search": {
        "enabled": false
      },
      "fetch": {
        "enabled": false
      }
    }
  },
  "skills": {
    "load": {
      "extraDirs": [
        "/data/workspace/skills"
      ]
    }
  }
}

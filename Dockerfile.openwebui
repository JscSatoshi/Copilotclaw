FROM python:3.11-slim

ARG OPEN_WEBUI_VERSION=0.9.2
ARG TORCH_INDEX_URL=https://download.pytorch.org/whl/cpu

ENV PYTHONDONTWRITEBYTECODE=1 \
    PYTHONUNBUFFERED=1 \
    PIP_NO_CACHE_DIR=1 \
    DATA_DIR=/app/backend/data \
    PORT=8080 \
    DOCKER=true \
    SCARF_NO_ANALYTICS=true \
    DO_NOT_TRACK=true \
    ANONYMIZED_TELEMETRY=false \
    OLLAMA_BASE_URL=/ollama \
    OPENAI_API_BASE_URL= \
    OPENAI_API_KEY= \
    HF_HUB_OFFLINE=1

WORKDIR /app

RUN apt-get update && \
    apt-get install -y --no-install-recommends curl && \
    rm -rf /var/lib/apt/lists/* && \
    pip install --no-cache-dir --index-url ${TORCH_INDEX_URL} 'torch<=2.9.1' && \
    pip install --no-cache-dir open-webui==${OPEN_WEBUI_VERSION}

RUN mkdir -p /app/backend/data /root/.cache/chroma && \
    echo -n 00000000-0000-0000-0000-000000000000 > /root/.cache/chroma/telemetry_user_id

EXPOSE 8080

CMD ["open-webui", "serve", "--host", "0.0.0.0", "--port", "8080"]